# Copy to .env.production, replace every placeholder, and never commit the result.
DOMAIN=shop.example.com
PUBLIC_BASE_URL=https://shop.example.com
NODE_ENV=production
PORT=4173

XPAY_ENV=production
XPAY_ALIAS=replace_with_nexi_alias
XPAY_SECRET_KEY=replace_with_nexi_secret_key
XPAY_CURRENCY=EUR
XPAY_LANGUAGE=ITA

ADMIN_TOKEN=replace_with_at_least_32_random_characters
ORDERS_DIR=/app/var/orders
PAYMENT_RATE_LIMIT=20
TRUST_PROXY=true

# Optional: set all three only when Hercules/Convex authentication is enabled.
VITE_CONVEX_URL=
VITE_HERCULES_OIDC_AUTHORITY=
VITE_HERCULES_OIDC_CLIENT_ID=
VITE_HERCULES_OIDC_PROMPT=select_account
VITE_HERCULES_OIDC_RESPONSE_TYPE=code
VITE_HERCULES_OIDC_SCOPE=openid profile email
VITE_HERCULES_OIDC_REDIRECT_URI=https://shop.example.com/auth/callback
VITE_HERCULES_WEBSITE_ID=
