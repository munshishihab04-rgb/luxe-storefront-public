# Public storefront URL used to build Nexi callback URLs.
# In production use your final HTTPS domain, e.g. https://www.example.com
DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost:4173

# Set to production only behind a final HTTPS domain. The server refuses
# production startup when required secrets are missing or placeholders.
NODE_ENV=development

# Nexi/XPay Classic hosted-payment credentials.
# Use "test" until Nexi activates your production alias/key.
XPAY_ENV=test
XPAY_ALIAS=your_xpay_alias_here
XPAY_SECRET_KEY=your_xpay_secret_key_here
XPAY_CURRENCY=EUR
XPAY_LANGUAGE=ITA

# Admin/catalog API protection. Use a long random value in production.
ADMIN_TOKEN=change_me_long_random_admin_token

# Optional server port for npm run serve:xpay
PORT=4173

# Runtime order storage. Back this directory up or mount a persistent volume.
ORDERS_DIR=./var/orders

# Payment creation attempts allowed per client in a 10-minute window.
PAYMENT_RATE_LIMIT=20

# Enable only behind a trusted reverse proxy that overwrites forwarding headers.
TRUST_PROXY=false

# Optional Convex/Hercules/OIDC configuration, only if auth backend is enabled.
VITE_CONVEX_URL=http://localhost:3000
HERCULES_OIDC_AUTHORITY=https://example-issuer.local
HERCULES_OIDC_CLIENT_ID=example-client-id
VITE_HERCULES_OIDC_AUTHORITY=https://example-issuer.local
VITE_HERCULES_OIDC_CLIENT_ID=example-client-id
VITE_HERCULES_OIDC_PROMPT=select_account
VITE_HERCULES_OIDC_RESPONSE_TYPE=code
VITE_HERCULES_OIDC_SCOPE=openid profile email
VITE_HERCULES_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_HERCULES_WEBSITE_ID=example-website-id
